{
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/women", "dest": "/women.html" },
    { "src": "/reviews", "dest": "/reviews.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/how-to-order", "dest": "/how-to-order.html" },
    { "src": "/women/([^/]+)", "dest": "/women.html" },
    { "src": "/reviews/([^/]+)", "dest": "/reviews.html" },
    { "src": "/faq/([^/]+)", "dest": "/faq.html" },
    { "src": "/how-to-order/([^/]+)", "dest": "/how-to-order.html" },
    { "src": "/([^/.]+)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
